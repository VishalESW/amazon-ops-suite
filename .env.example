# Copy to .env and fill in. Never commit the real .env.

# ---- Flask ----------------------------------------------------------------
FLASK_SECRET_KEY=change-me-to-a-random-64-hex-string
FERNET_KEY=generate-with: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"

# ---- Public base URL (ngrok / public https for real OAuth) ----------------
APP_BASE_URL=http://localhost:5000

# ---- Amazon LWA client (SP-API + Advertising share this) ------------------
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=
SPAPI_APPLICATION_ID=
SPAPI_APP_DRAFT=true
SPP_CLIENT_ID=
SPP_CLIENT_SECRET=

# ---- AWS (not used for signing on modern SP-API) --------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ROLE_ARN=

# ---- SP-API ---------------------------------------------------------------
SPAPI_REGION=NA
SPAPI_ENDPOINT=https://sellingpartnerapi-na.amazon.com
SPAPI_DEFAULT_MARKETPLACE_ID=ATVPDKIKX0DER
LWA_TOKEN_URL=https://api.amazon.com/auth/o2/token

# ---- Amazon Advertising API ----------------------------------------------
ADS_API_ENDPOINT=https://advertising-api.amazon.com
ADS_SCOPE=advertising::campaign_management

# ---- AI summary endpoint --------------------------------------------------
AI_API_URL=
AI_API_KEY=
AI_CHAT_PATH=/v1/chat/completions
AI_MODEL=gpt-3.5-turbo
